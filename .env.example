# MediGuide AI Environment Variables
# Copy this to .env and fill in your values
# DO NOT commit .env to version control

# HuggingFace Token - get from https://huggingface.co/settings/tokens
HF_TOKEN=

# API Base URL (use router for best performance)
API_BASE_URL=https://router.huggingface.co/v1

# Model name - MedGemma-27B-it for medical diagnosis
MODEL_NAME=MedGemma-27B-it

# Task configuration
TASK_NAME=mediguide
BENCHMARK=mediguide

# Local Docker image (optional - for from_docker_image method)
LOCAL_IMAGE_NAME=